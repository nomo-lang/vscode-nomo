{
  "name": "vscode-nomo",
  "displayName": "Nomo",
  "description": "Nomo language support: diagnostics, completion, formatting and syntax highlighting via the Nomo language server.",
  "version": "0.0.0-20260713145859",
  "publisher": "nomo-lang",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nomo-lang/vscode-nomo.git"
  },
  "homepage": "https://github.com/nomo-lang/vscode-nomo#readme",
  "bugs": {
    "url": "https://github.com/nomo-lang/vscode-nomo/issues"
  },
  "keywords": [
    "nomo",
    "language-server",
    "lsp",
    "programming-language"
  ],
  "galleryBanner": {
    "color": "#202733",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "activationEvents": [
    "onLanguage:nomo"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "nomo",
        "aliases": [
          "Nomo",
          "nomo"
        ],
        "extensions": [
          ".nomo"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "nomo",
        "scopeName": "source.nomo",
        "path": "./syntaxes/nomo.tmLanguage.json"
      }
    ],
    "configuration": {
      "title": "Nomo",
      "properties": {
        "nomo.lsp.path": {
          "type": "string",
          "default": "nomo-lsp",
          "description": "Path to the nomo-lsp language server executable. Defaults to looking it up on PATH."
        },
        "nomo.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Trace the communication between VS Code and the Nomo language server."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --format=cjs --platform=node",
    "build:test": "esbuild src/server-config.ts --bundle --outfile=dist-test/server-config.js --format=cjs --platform=node",
    "test": "npm run build:test && node --test",
    "watch": "npm run build -- --sourcemap --watch",
    "package": "vsce package",
    "publish:marketplace": "vsce publish",
    "publish:openvsx": "ovsx publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.75.0",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.28.1",
    "ovsx": "^1.0.2",
    "typescript": "^5.4.0"
  }
}
