{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Nomo",
  "scopeName": "source.nomo",
  "patterns": [
    { "include": "#comments" },
    { "include": "#attributes" },
    { "include": "#strings" },
    { "include": "#keywords" },
    { "include": "#operators" },
    { "include": "#constants" },
    { "include": "#numbers" },
    { "include": "#types" },
    { "include": "#functions" },
    { "include": "#variants" }
  ],
  "repository": {
    "attributes": {
      "patterns": [
        {
          "match": "(#)(\\[)([a-z_][A-Za-z0-9_]*)(\\])",
          "captures": {
            "1": { "name": "punctuation.definition.attribute.nomo" },
            "2": { "name": "punctuation.section.brackets.begin.nomo" },
            "3": { "name": "entity.other.attribute-name.nomo" },
            "4": { "name": "punctuation.section.brackets.end.nomo" }
          }
        }
      ]
    },
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.nomo",
          "match": "//.*$"
        },
        {
          "name": "comment.block.nomo",
          "begin": "/\\*",
          "end": "\\*/"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.nomo",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.nomo",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.nomo",
          "match": "'(\\\\.|[^'\\\\])'"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.nomo",
          "match": "\\b(if|else|match|for|in|return|defer|unsafe|break|continue|panic)\\b"
        },
        {
          "name": "keyword.declaration.nomo",
          "match": "\\b(package|import|pub|fn|struct|enum|interface|impl|extern|let|mut|const)\\b"
        },
        {
          "name": "keyword.operator.cast.nomo",
          "match": "\\bas\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "match": "\\b(const)\\s+([A-Z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.nomo" },
            "2": { "name": "constant.other.nomo" }
          }
        },
        {
          "name": "constant.language.nomo",
          "match": "\\b(true|false|void|self)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.nomo",
          "match": "&\\^=|<<=|>>=|==|!=|<=|>=|\\+=|-=|\\*=|/=|%=|&=|\\^=|\\|=|\\+\\+|--|&&|\\|\\||&\\^|<<|>>|->|=>|\\?|!|\\+|-|\\*|/|%|&|\\||\\^|=|<|>"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.nomo",
          "match": "\\b[0-9]+\\.[0-9]+\\b"
        },
        {
          "name": "constant.numeric.integer.nomo",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.nomo",
          "match": "\\b(bool|i32|i64|u32|u64|f64|char|string|void)\\b"
        },
        {
          "name": "entity.name.type.nomo",
          "match": "\\b[A-Z][A-Za-z0-9_]*\\b"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "match": "\\b(fn)\\s+([a-z_][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "keyword.declaration.nomo" },
            "2": { "name": "entity.name.function.nomo" }
          }
        },
        {
          "name": "entity.name.function.call.nomo",
          "match": "\\b([a-z_][A-Za-z0-9_]*)\\s*(?=\\()"
        }
      ]
    },
    "variants": {
      "patterns": [
        {
          "match": "\\b([A-Z][A-Za-z0-9_]*)\\.([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.nomo" },
            "2": { "name": "variable.other.enummember.nomo" }
          }
        }
      ]
    }
  }
}
